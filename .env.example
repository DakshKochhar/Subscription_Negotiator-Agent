# ====================================================================
# Core Google GenAI Authentication
# ====================================================================
# Retrieve your key from Google AI Studio (https://aistudio.google.com/)
GOOGLE_API_KEY="YOUR_GOOGLE_API_KEY_HERE"

# ====================================================================
# Google Workspace MCP Server Configurations
# ====================================================================
# Paste your raw OAuth client credentials JSON payload string here
# Required to access your personal Gmail account's 'Drafts' workspace folder
WORKSPACE_JSON_KEY="YOUR_WORKSPACE_OAUTH_JSON_PAYLOAD_HERE"

# ====================================================================
# OpenFinance / Plaid Sandbox Credentials
# ====================================================================
# Standard development sandbox keys for transaction ledger testing
PLAID_CLIENT_ID="YOUR_PLAID_CLIENT_ID_HERE"
PLAID_SECRET="YOUR_PLAID_SECRET_HERE"
